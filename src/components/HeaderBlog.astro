---
import { blog, global } from "../strings";
import { paths } from "../config";
import { Image } from "astro:assets";
import logo from "../../assets/logo.png";
---

<header class="header">
  <a class="logo" href={paths.blog} aria-label={blog.homeLinkAlt}>
    <Image src={logo} alt={global.header.logoAlt} />
  </a>
  <nav class="nav">
    <a href={paths.about}>{blog.aboutLink}</a>
  </nav>
</header>

<style>
  .header {
    --padding: max(1rem, calc((100vw - var(--content-width)) / 2));

    background-color: var(--color-primary);
    height: var(--blog-header-height);
    width: calc(100vw - var(--padding) * 2);
    padding: 1rem var(--padding);

    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    height: var(--blog-header-height);
    width: var(--blog-header-height);
    display: block;

    img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
  }

  .nav {
    margin: 0 4rem 0 1rem;
    
    a {
      color: var(--color-white);
      font: var(--font-blog-header-nav);
      text-decoration: none;
    }
  }
</style>
