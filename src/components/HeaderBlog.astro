---
import { blog, global } from '../data/strings';
import { paths } from '../data/config';
---

<header class="header">
  <a class="logo" href={paths.blog} aria-label={blog.homeLinkAlt}>
    <img src="/images/logo.png" alt={global.header.logoAlt} width="64" height="64" />
  </a>
  <nav class="nav">
    <a href={paths.about}>{blog.aboutLink}</a>
  </nav>
</header>

<style>
  .header {
    --padding: max(1rem, calc((100vw - var(--content-width)) / 2));

    background-color: var(--color-primary);
    height: var(--blog-header-height);
    width: calc(100vw - var(--padding) * 2);
    padding: 1rem var(--padding);

    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    height: var(--blog-header-height);
    width: var(--blog-header-height);
    display: block;
  }

  .logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .nav {
    margin: 0 4rem 0 1rem;
  }

  .nav a {
    color: var(--color-white);
    font: var(--font-blog-header-nav);
    text-decoration: none;
  }
</style>
